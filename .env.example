# Polymarket Trading Bot - Environment Variables
# Copy this file to .env and fill in your values

# Polymarket US API credentials (get from polymarket.us/developer)
POLYMARKET_KEY_ID=your_key_id_here
POLYMARKET_SECRET_KEY=your_secret_key_here

# Slack webhook URL for trade alerts (optional)
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# The Odds API key for consensus odds comparison (REQUIRED for trading)
# Free tier: 500 requests/month at https://the-odds-api.com
THE_ODDS_API_KEY=your_odds_api_key_here
